# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Same values as above (Vercel / server + Edge; runtime — helps if a build was made before NEXT_PUBLIC_ was set)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional: absolute public URL for media previews in emails or absolute links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dashboard: background pull from Supabase (ms). Minimum 15000. Default 120000 (2 min).
# NEXT_PUBLIC_CONSOLE_SYNC_INTERVAL_MS=120000
